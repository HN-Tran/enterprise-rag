# Postgres
PG_DSN=postgresql://rag:rag@localhost:5432/ragdb

# Neo4j amplifier (optional)
USE_NEO4J=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# Embeddings (OpenAI-compatible)
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_MODEL=qwen3-embedding-8b
EMBED_API_KEY=
EMBED_DIM=4096

# Reranker - TEI (Text Embeddings Inference) with cross-encoder
# Runs via docker-compose, much faster than LLM-based reranking
RERANK_ENABLED=true
RERANK_BASE_URL=http://localhost:9001
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=

# LLM for query planning + evidence extraction + answering (OpenAI-compatible chat)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3-32b-instruct
LLM_API_KEY=
LLM_CONTEXT_LENGTH=16000

# Ingestion / windowing
WINDOW_PAGES=2
WINDOW_STRIDE=1
MAX_WINDOW_CHARS=24000
MAX_ANCHOR_CHARS=2000

# Retrieval
CANDIDATES_BM25=120
CANDIDATES_VEC=120
RERANK_KEEP=18
MAX_PER_DOC=2
MAX_QUERY_REWRITES=6

# Category boosting
CATEGORY_BOOST=1.20

# Context packing - how much context to prepare for LLM
PACK_MAX_SOURCES=8
PACK_CHARS_PER_SOURCE=3000
PACK_MAX_CITED_DOCS=2

# Evidence extraction - context sent for answer generation
# Lower values = faster responses, higher = more comprehensive
EVIDENCE_MAX_WINDOWS=4
EVIDENCE_CHARS_PER_WINDOW=1000
EVIDENCE_MAX_ANCHORS=2
EVIDENCE_CHARS_PER_ANCHOR=600
EVIDENCE_FALLBACK_ANSWER_CHARS=3000
EVIDENCE_FALLBACK_SNIPPET_CHARS=200

# Reranker limits
RERANK_CHARS_PER_DOC=2000

# LLM output limits (prevents infinite generation)
LLM_MAX_ANSWER_TOKENS=500

# --- Phase 4: Operational Improvements ---

# Connection pooling
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30.0

# Redis caching (optional - leave empty to disable)
REDIS_URL=redis://localhost:56379/0
CACHE_EMBED_TTL=86400
CACHE_QUERY_TTL=3600

# Async ingestion (requires Redis)
ASYNC_INGEST=false

# Observability
OTEL_ENDPOINT=http://localhost:4317
LOG_JSON=true
LOG_LEVEL=INFO
